{
  "name": "diamondlightsource/synchweb",
  "description": "A web interface for ISPyB",
  "keywords": [
    "SynchWeb",
    "ISPyB"
  ],
  "homepage": "https://github.com/DiamondLightSource/SynchWeb",
  "license": "Apache-2.0",
  "repositories": [
    {
      "type": "github",
      "url": "https://github.com/mattprit/dhl-api.git"
    }
  ],
  "require": {
    "apereo/phpcas": "1.6.1",
    "ezyang/htmlpurifier": "^4.12.0",
    "firebase/php-jwt": "^6.0.0",
    "jdorn/sql-formatter": "^1.2.9",
    "mpdf/mpdf": "^8.1.2",
    "slim/slim": "^2.6.2",
    "php-amqplib/php-amqplib": "^3.0",
    "symfony/http-foundation": "^5.4",
    "symfony/filesystem": "^5.4",
    "mpdf/qrcode": "^1.2",
    "mtcmedia/dhl-api": "dev-master#9b4b6315",
    "maennchen/zipstream-php": "^2.1.0",
    "ext-bcmath": "*"
  },
  "autoload": {
    "psr-4": {
      "SynchWeb\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9",
    "php-mock/php-mock-phpunit": "^2.6",
    "mockery/mockery": "^1.5",
    "vimeo/psalm": "^5.0"
  },
  "config": {
    "platform": {
      "php": "7.4.33"
    },
    "audit": {
      "ignore": ["PKSA-y2cr-5h3j-g3ys"]
    }
  }
}
